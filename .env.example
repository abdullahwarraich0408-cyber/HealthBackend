PORT=5000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/pharmahub"
REDIS_URL="redis://localhost:6379"
# Local dev: omit Redis install and use in-memory cache (default in development).
# Set REDIS_ENABLED=true when Redis/Memurai/Docker redis is running.
REDIS_ENABLED=false

# Security
JWT_ACCESS_SECRET="secret123"
JWT_REFRESH_SECRET="secret123456"

# DigitalOcean Spaces (S3 Compatible)
DO_SPACES_ENDPOINT="https://nyc3.digitaloceanspaces.com"
DO_SPACES_REGION="nyc3"
DO_SPACES_KEY="your_do_key"
DO_SPACES_SECRET="your_do_secret"
DO_SPACES_BUCKET="pharmahub-assets"

# Email / SMS
RESEND_API_KEY="re_12345"
TWILIO_ACCOUNT_SID="ACxxx"
TWILIO_AUTH_TOKEN="xxx"

# Meilisearch
MEILISEARCH_HOST="http://127.0.0.1:7700"
MEILISEARCH_API_KEY="masterKey"

# Stripe (sandbox)
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
STRIPE_CURRENCY="pkr"
FRONTEND_URL="http://localhost:3000"

# Allow dev test OTP login in production (staging hub.asrar.dev / medmarket.asrar.dev)
ENABLE_TEST_AUTH=true
